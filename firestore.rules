rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Development only: open read, authenticated write.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Production example (commented):
    // function isAdmin() {
    //   return request.auth != null && request.auth.token.role == 'admin';
    // }
    // function isMember(appId, section, halaqaId) {
    //   return request.auth != null &&
    //     get(/databases/$(database)/documents/apps/$(appId)/sections/$(section)/halaqas/$(halaqaId)).data.members[request.auth.uid] == true;
    // }
    // match /apps/{appId}/sections/{section}/halaqas/{halaqaId} {
    //   allow read, write: if isAdmin() || isMember(appId, section, halaqaId);
    //   match /students/{studentId} {
    //     allow read, write: if isAdmin() || isMember(appId, section, halaqaId);
    //     match /weeks/{weekId} {
    //       allow read, write: if isAdmin() || isMember(appId, section, halaqaId);
    //     }
    //   }
    // }
  }
}
